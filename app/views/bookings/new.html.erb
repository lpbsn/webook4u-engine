<div class="booking-header">
  <h1 class="booking-header-title"><%= @client.name %></h1>
  <p class="booking-header-subtitle"><%= @service.name %></p>
</div>

<div class="booking-summary">
  <h2 class="booking-section-title">Créneau choisi</h2>
  <div class="booking-fields">
    <p><%= @booking_start_time.strftime("%d/%m/%Y à %H:%M") %></p>
  </div>
</div>

<% if @booking.errors.any? %>
  <div class="booking-errors">
    <strong>Le formulaire contient des erreurs :</strong>
    <ul>
      <% @booking.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<%= form_with model: @booking, url: confirm_booking_path(@client.slug, @booking), method: :post do |form| %>
  <div class="field">
    <label class="field-label" for="booking_customer_first_name">Prénom</label>
    <%= form.text_field :customer_first_name, required: true, class: "field-input" %>
  </div>

  <div class="field">
    <label class="field-label" for="booking_customer_last_name">Nom</label>
    <%= form.text_field :customer_last_name, required: true, class: "field-input" %>
  </div>

  <div class="field">
    <label class="field-label" for="booking_customer_email">Email</label>
    <%= form.email_field :customer_email, required: true, class: "field-input" %>
  </div>

  <div class="field">
    <%= form.submit "Valider la réservation", class: "btn-primary" %>
  </div>
<% end %>
