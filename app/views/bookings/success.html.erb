<% content_for :booking_card_modifier, "booking-success" %>

<div class="booking-success-body">
  <h1 class="booking-success-title">Votre réservation est confirmée</h1>
  <p><strong>Client :</strong> <%= @client.name %></p>
  <p><strong>Utilisateur :</strong> <%= booking_customer_name(@booking) %></p>
  <p><strong>Email :</strong> <%= @booking.customer_email %></p>
  <p><strong>Prestation :</strong> <%= @service.name %></p>
  <p><strong>Créneau :</strong> <%= booking_formatted_slot(@booking) %></p>
</div>
