<!-- ===================================================== -->
<!-- ÉTAPE 2 : CHOIX DE LA DATE -->
<!-- ===================================================== -->

<% if @selected_service.present? %>
  <hr>

  <h2>2. Choisissez une date</h2>

  <p>
    <strong>Prestation sélectionnée :</strong>
    <%= @selected_service.name %>
  </p>

  <p>
    <strong>Durée :</strong>
    <%= @selected_service.duration_minutes %> minutes
  </p>

  <p>
    <strong>Prix :</strong>
    <%= public_client_service_price(@selected_service) %>
  </p>

  <%= form_with url: public_client_path(@client.slug), method: :get, local: true do %>
    <%= hidden_field_tag :service_id, @selected_service.id %>

    <div>
      <%= label_tag :date, "Date" %><br>
      <%= date_field_tag :date, params[:date], required: true %>
    </div>

    <br>

    <%= submit_tag "Voir les créneaux disponibles" %>
  <% end %>
<% end %>

