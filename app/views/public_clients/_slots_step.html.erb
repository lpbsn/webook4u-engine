<% if @selected_service.present? && @date.present? %>
  <div class="booking-section">
    <h2 class="booking-section-title">3. Choisissez un créneau</h2>
    <p class="booking-section-meta">
      <strong><%= @selected_service.name %></strong> — <%= public_client_formatted_date(@date) %>
    </p>

    <% if @slots.any? %>
      <div class="slot-grid">
        <% @slots.each do |slot| %>
          <%= form_with url: new_service_booking_path(@client.slug, @selected_service), method: :get, local: true do %>
            <%= hidden_field_tag :start_time, slot %>
            <%= submit_tag public_client_slot_label(slot), class: "slot-button" %>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <p>Aucun créneau n'est disponible pour cette date. Veuillez choisir une autre date.</p>
    <% end %>
  </div>
<% end %>

